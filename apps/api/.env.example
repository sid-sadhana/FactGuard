# Template for .env.local and .env.production.
# Copy to .env.local (dev) or .env.production (prod) and fill in secrets.
# The active file is picked by APP_ENV (defaults to "local").

# --- runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- ollama ---
# Local:      OLLAMA_BASE_URL=http://localhost:11434  (no API key)
# Cloud:      OLLAMA_BASE_URL=https://ollama.com      (set OLLAMA_API_KEY)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3-vl
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_API_KEY=

# --- web search ---
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=5

# --- pipeline tuning ---
STORAGE_DIR=./.factguard-storage
MAX_UPLOAD_MB=500
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=4
CONTEXT_BUDGET_CHARS=6000
ENABLE_RAGAS=false
# Fetch full page text with langchain WebBaseLoader (Tavily provides URLs).
# Set to false to use Tavily's raw_content directly.
USE_WEB_BASE_LOADER=true

# --- qdrant (production) ---
# Per-job collections are created, queried, then dropped at end of pipeline.
USE_QDRANT=false
QDRANT_URL=
QDRANT_API_KEY=
