# Template for .env.local — the only env file the project uses.
# Copy to .env.local and fill in secrets.

# --- runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- ollama (LLM only, local instance — embeddings run on Qdrant Cloud Inference) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:e4b
OLLAMA_API_KEY=

# --- embeddings: Qdrant Cloud Inference (server-side, no Ollama embed) ---
EMBED_MODEL=sentence-transformers/all-minilm-l6-v2
EMBED_DIM=384

# --- web search: DuckDuckGo via ddgs, no API key ---
# Optional proxy (http://user:pass@host:port or socks5://host:port) if DDG
# rate-limits you. Leave blank to call DDG directly.
DDGS_PROXY=
SEARCH_MAX_RESULTS=5
SEARCH_REGION=wt-wt

# --- pipeline tuning ---
STORAGE_DIR=./.factguard-storage
MAX_UPLOAD_MB=500
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=4
CONTEXT_BUDGET_CHARS=6000
ENABLE_RAGAS=false
# Fetch full page text with langchain WebBaseLoader (DDG provides URLs).
# Set to false to use DDG's own short snippet directly.
USE_WEB_BASE_LOADER=true

# --- qdrant ---
# Required: per-job collections are created, queried, then dropped at end of pipeline.
QDRANT_URL=
QDRANT_API_KEY=
